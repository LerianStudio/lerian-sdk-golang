# Lerian SDK Environment Variables
#
# Auth pattern for all products:
# - Use the complete *_CLIENT_ID + *_CLIENT_SECRET + *_TOKEN_URL triplet for
#   OAuth2 client-credentials auth.

# -----------------------------------------------------------------------------
# Global
# -----------------------------------------------------------------------------
LERIAN_DEBUG=false

# -----------------------------------------------------------------------------
# Midaz
# Required: LERIAN_MIDAZ_ONBOARDING_URL, LERIAN_MIDAZ_TRANSACTION_URL
# Optional: LERIAN_MIDAZ_CRM_URL
# Auth: optional
# -----------------------------------------------------------------------------
LERIAN_MIDAZ_ONBOARDING_URL=http://localhost:3000/v1
LERIAN_MIDAZ_TRANSACTION_URL=http://localhost:3001/v1
LERIAN_MIDAZ_CRM_URL=http://localhost:4003/v1
LERIAN_MIDAZ_CLIENT_ID=
LERIAN_MIDAZ_CLIENT_SECRET=
LERIAN_MIDAZ_TOKEN_URL=

# -----------------------------------------------------------------------------
# Matcher
# Required: LERIAN_MATCHER_URL
# Auth: optional
# -----------------------------------------------------------------------------
LERIAN_MATCHER_URL=http://localhost:3002/v1
LERIAN_MATCHER_CLIENT_ID=
LERIAN_MATCHER_CLIENT_SECRET=
LERIAN_MATCHER_TOKEN_URL=

# -----------------------------------------------------------------------------
# Tracer
# Required: LERIAN_TRACER_URL
# Auth: optional
# -----------------------------------------------------------------------------
LERIAN_TRACER_URL=http://localhost:3003/v1
LERIAN_TRACER_CLIENT_ID=
LERIAN_TRACER_CLIENT_SECRET=
LERIAN_TRACER_TOKEN_URL=

# -----------------------------------------------------------------------------
# Reporter
# Required: LERIAN_REPORTER_URL, LERIAN_REPORTER_ORG_ID
# Auth: optional
# -----------------------------------------------------------------------------
LERIAN_REPORTER_URL=http://localhost:3004/v1
LERIAN_REPORTER_ORG_ID=
LERIAN_REPORTER_CLIENT_ID=
LERIAN_REPORTER_CLIENT_SECRET=
LERIAN_REPORTER_TOKEN_URL=

# -----------------------------------------------------------------------------
# Fees
# Required: LERIAN_FEES_URL, LERIAN_FEES_ORG_ID
# Auth: optional
# -----------------------------------------------------------------------------
LERIAN_FEES_URL=http://localhost:3005/v1
LERIAN_FEES_ORG_ID=
LERIAN_FEES_CLIENT_ID=
LERIAN_FEES_CLIENT_SECRET=
LERIAN_FEES_TOKEN_URL=
