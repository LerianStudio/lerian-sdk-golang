# Tracer (Audit Trail)
LERIAN_TRACER_URL=http://localhost:3003/v1
LERIAN_TRACER_API_KEY=

# Reporter (Analytics)
LERIAN_REPORTER_URL=http://localhost:3004/v1
LERIAN_REPORTER_AUTH_TOKEN=
LERIAN_REPORTER_ORG_ID=

# Fees (Billing)
LERIAN_FEES_URL=http://localhost:3005/v1
LERIAN_FEES_AUTH_TOKEN=
LERIAN_FEES_ORG_ID=
